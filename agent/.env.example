# GitHub
GITHUB_TOKEN=github_pat_xxxx
GITHUB_REPO=glossagens/glossagens

# Webhook-Sicherheit
WEBHOOK_SECRET=ein-langes-zufaelliges-passwort

# LLM (OpenAI-kompatibler Endpunkt, z.B. Ollama oder externer Service)
LLM_API_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_MODEL=hermes3

# Email-Benachrichtigung
OWNER_EMAIL=deine@email.ch
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=absender@email.ch
SMTP_PASS=passwort

# OpenWebUI Tools (URL dieses Servers, von OpenWebUI aus erreichbar)
AGENT_API_URL=https://agent.deine-domain.ch
AGENT_API_KEY=ein-weiteres-passwort

# Datenbank
DB_PATH=/var/lib/glossagens/queue.db
